{
  "name": "orta_note",
  "version": "1.0.0",
  "description": "Editor de notas ligero y rápido para Sysadmins, con sintaxis Orta.",
  "author": "José Orta",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.jose.ortanote",
    "productName": "OrtaNote",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "portable"
      ]
    }
  },
  "dependencies": {
    "quill": "^1.3.7",
    "quill-image-resize-module": "^3.0.0"
  },
  "devDependencies": {
    "electron": "^28.2.3",
    "electron-builder": "^24.9.1"
  }
}
